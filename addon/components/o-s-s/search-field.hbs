<OSS::InputContainer @value={{this.value}} @placeholder={{this.placeholder}} @onChange={{this.onChange}}>
  <:prefix>
    <OSS::Icon @icon="fa-search" class="font-color-gray-500" />
  </:prefix>
  <:suffix>
    {{#if (gt this.value.length 0)}}
      <OSS::Icon @icon="fa-times" class="font-color-gray-500" role="button" {{on "click" this.onClearSearch}} />
    {{/if}}
  </:suffix>
</OSS::InputContainer>